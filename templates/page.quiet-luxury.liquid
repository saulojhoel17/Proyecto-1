{% comment %} Full custom storefront template for the quiet-luxury boutique experience. {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    color-scheme: light;
    font-family: 'Manrope', sans-serif;
    --bg: #f6f2eb;
    --surface: #fcfaf7;
    --surface-2: #e9e2d8;
    --text: #111827;
    --muted: #6c7483;
    --primary: #0d1b2a;
    --primary-soft: #6f7c8f;
    --border: #e8e2d9;
    --shadow: 0 18px 45px rgba(13, 27, 42, 0.08);
  }

  .quiet-luxury-root * { box-sizing: border-box; }
  .quiet-luxury-root {
    margin: 0;
    padding: 0;
    background: linear-gradient(135deg, #f8f2eb 0%, #fdfbf8 100%);
    color: var(--text);
    font-family: 'Manrope', sans-serif;
  }

  .quiet-luxury-root button { font: inherit; }

  .quiet-luxury-root .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 2rem;
    border-bottom: 1px solid var(--border);
    background: rgba(252, 250, 247, 0.95);
    backdrop-filter: blur(14px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .quiet-luxury-root .brand-block { display: flex; align-items: center; gap: 0.8rem; }
  .quiet-luxury-root .brand-mark {
    display: grid; place-items: center; width: 46px; height: 46px;
    border-radius: 14px; background: linear-gradient(135deg, var(--primary), #3a3a3a);
    color: white; font-weight: 700; letter-spacing: 0.08em;
  }
  .quiet-luxury-root .eyebrow {
    margin: 0 0 0.2rem; text-transform: uppercase; letter-spacing: 0.24em;
    font-size: 0.72rem; color: var(--primary-soft); font-weight: 700;
  }
  .quiet-luxury-root h1, .quiet-luxury-root h2, .quiet-luxury-root h3, .quiet-luxury-root h4, .quiet-luxury-root p { margin: 0; }
  .quiet-luxury-root h2, .quiet-luxury-root h3, .quiet-luxury-root h4 {
    font-family: 'Cormorant Garamond', serif; letter-spacing: 0.01em;
  }

  .quiet-luxury-root .topnav { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .quiet-luxury-root .tab {
    border: 1px solid transparent; background: transparent; color: var(--muted);
    padding: 0.65rem 0.95rem; border-radius: 999px; cursor: pointer;
    transition: all 180ms ease;
  }
  .quiet-luxury-root .tab.active {
    background: var(--primary); color: white; box-shadow: 0 10px 24px rgba(28, 28, 28, 0.15);
  }

  .quiet-luxury-root .app-shell {
    display: grid; grid-template-columns: 1.7fr 0.8fr; gap: 1.25rem; padding: 1.25rem 2rem 2rem;
  }
  .quiet-luxury-root .hero-panel {
    display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 1rem; padding: 1.3rem;
    border-radius: 30px; background: var(--surface); box-shadow: var(--shadow); overflow: hidden;
  }
  .quiet-luxury-root .hero-copy-block { padding: 1rem; display: flex; flex-direction: column; justify-content: center; }
  .quiet-luxury-root .hero-copy-block h2 {
    font-size: clamp(1.8rem, 2.8vw, 2.8rem); margin-bottom: 0.8rem; max-width: 560px; line-height: 1.03;
  }
  .quiet-luxury-root .hero-copy { color: var(--muted); max-width: 560px; margin-bottom: 1.2rem; line-height: 1.7; }
  .quiet-luxury-root .primary-btn, .quiet-luxury-root .add-btn, .quiet-luxury-root .checkout-btn {
    border: none; border-radius: 999px; cursor: pointer; font-weight: 600;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }
  .quiet-luxury-root .primary-btn:hover, .quiet-luxury-root .add-btn:hover, .quiet-luxury-root .checkout-btn:hover {
    transform: translateY(-1px);
  }
  .quiet-luxury-root .primary-btn {
    display: inline-flex; align-items: center; justify-content: center; padding: 0.9rem 1.2rem;
    background: var(--primary); color: white; text-decoration: none; box-shadow: 0 12px 24px rgba(28, 28, 28, 0.16);
  }
  .quiet-luxury-root .hero-visual {
    position: relative; min-height: 270px; border-radius: 24px;
    background: linear-gradient(135deg, #0d1b2a 0%, #26364d 45%, #e7ddcf 100%);
    display: flex; align-items: flex-end; justify-content: flex-start; padding: 1rem;
  }
  .quiet-luxury-root .hero-badge {
    position: relative; z-index: 2; background: rgba(255, 255, 255, 0.92); padding: 0.7rem 0.95rem;
    border-radius: 999px; font-size: 0.9rem; color: var(--text);
  }
  .quiet-luxury-root .hero-glow {
    position: absolute; inset: 20px; border-radius: 20px; border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .quiet-luxury-root .catalog-section { margin-top: 1.2rem; }
  .quiet-luxury-root .section-heading {
    display: flex; justify-content: space-between; align-items: end; gap: 1rem; margin-bottom: 0.9rem;
  }
  .quiet-luxury-root .section-heading > p { color: var(--muted); max-width: 340px; text-align: right; }
  .quiet-luxury-root .product-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; transition: opacity 220ms ease;
  }
  .quiet-luxury-root .product-grid.is-changing { opacity: 0.3; }
  .quiet-luxury-root .product-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 1rem;
    display: flex; flex-direction: column; gap: 0.8rem; box-shadow: var(--shadow);
    transition: transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 280ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 280ms ease;
  }
  .quiet-luxury-root .product-card:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 22px 50px rgba(13, 27, 42, 0.12); }
  .quiet-luxury-root .product-visual {
    display: flex; align-items: center; justify-content: center; width: 100%; min-height: 148px; border-radius: 18px;
    border: 1px solid var(--border); background: linear-gradient(135deg, #f7efe8 0%, #ece4d9 100%); cursor: pointer; padding: 0.9rem;
  }
  .quiet-luxury-root .product-visual::before {
    content: 'Muestra de producto'; display: grid; place-items: center; width: 100%; height: 100%; border: 1px solid rgba(13, 27, 42, 0.1);
    border-radius: 14px; color: var(--primary-soft); font-size: 0.85rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600;
  }
  .quiet-luxury-root .product-badge {
    display: inline-flex; width: fit-content; padding: 0.35rem 0.6rem; border-radius: 999px; background: var(--surface-2);
    color: var(--muted); font-size: 0.75rem; font-weight: 700;
  }
  .quiet-luxury-root .product-card h4 { font-size: 1.05rem; margin-bottom: 0.2rem; }
  .quiet-luxury-root .product-card p { color: var(--muted); font-size: 0.95rem; line-height: 1.6; }
  .quiet-luxury-root .product-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
  .quiet-luxury-root .product-footer span { font-weight: 700; }
  .quiet-luxury-root .add-btn { padding: 0.7rem 0.95rem; background: var(--primary); color: white; }
  .quiet-luxury-root .cart-panel {
    background: var(--surface); border: 1px solid var(--border); border-radius: 28px; padding: 1.2rem;
    align-self: start; box-shadow: var(--shadow);
  }
  .quiet-luxury-root .cart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .quiet-luxury-root .pill {
    background: var(--surface-2); color: var(--primary); padding: 0.4rem 0.7rem; border-radius: 999px; font-weight: 700;
  }
  .quiet-luxury-root .cart-items { display: flex; flex-direction: column; gap: 0.8rem; min-height: 180px; }
  .quiet-luxury-root .cart-item {
    display: flex; justify-content: space-between; align-items: center; gap: 0.8rem; padding: 0.8rem; border-radius: 16px; background: var(--surface-2);
  }
  .quiet-luxury-root .cart-item strong { display: block; margin-bottom: 0.25rem; }
  .quiet-luxury-root .empty-cart { color: var(--muted); margin-top: 1rem; }
  .quiet-luxury-root .cart-summary { border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 1rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .quiet-luxury-root .summary-row { display: flex; justify-content: space-between; align-items: center; }
  .quiet-luxury-root .checkout-btn { padding: 0.9rem 1rem; background: var(--text); color: white; }
  .quiet-luxury-root .modal { position: fixed; inset: 0; z-index: 80; display: grid; place-items: center; padding: 1rem; animation: fadeIn 260ms ease; }
  .quiet-luxury-root .modal.hidden { display: none; }
  .quiet-luxury-root .modal-backdrop { position: absolute; inset: 0; background: rgba(15, 15, 15, 0.62); backdrop-filter: blur(8px); animation: backdropIn 260ms ease; }
  .quiet-luxury-root .modal-card {
    position: relative; z-index: 1; display: grid; grid-template-columns: 0.9fr 1fr; gap: 1rem; width: min(920px, 100%);
    background: var(--surface); border-radius: 28px; padding: 1rem; box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
    animation: modalRise 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .quiet-luxury-root .modal-close { position: absolute; top: 0.8rem; right: 0.8rem; border: none; background: transparent; color: var(--text); font-size: 1.4rem; cursor: pointer; }
  .quiet-luxury-root .modal-gallery { display: flex; flex-direction: column; gap: 0.8rem; }
  .quiet-luxury-root .modal-visual {
    min-height: 320px; border-radius: 24px; background: linear-gradient(135deg, #f7efe8 0%, #ece4d9 100%);
    display: grid; place-items: center; padding: 1rem;
  }
  .quiet-luxury-root .modal-visual::before {
    content: 'Muestra de producto'; display: grid; place-items: center; width: 100%; height: 100%; border: 1px solid rgba(13, 27, 42, 0.12);
    border-radius: 18px; color: var(--primary-soft); font-size: 0.95rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600;
  }
  .quiet-luxury-root .thumbnail-row { display: flex; gap: 0.6rem; }
  .quiet-luxury-root .thumbnail-btn {
    border: 1px solid var(--border); background: var(--surface); border-radius: 14px; padding: 0.6rem; font-size: 1.2rem; cursor: pointer;
    transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
  }
  .quiet-luxury-root .thumbnail-btn:hover { transform: translateY(-1px); border-color: var(--primary-soft); }
  .quiet-luxury-root .thumbnail-btn.active { border-color: var(--primary); background: var(--surface-2); }
  .quiet-luxury-root .modal-details { padding: 0.6rem 0.4rem 0.4rem 0.4rem; display: flex; flex-direction: column; gap: 0.8rem; }
  .quiet-luxury-root .modal-description { color: var(--muted); line-height: 1.7; }
  .quiet-luxury-root .benefits-list { padding-left: 1rem; color: var(--text); display: grid; gap: 0.4rem; }
  .quiet-luxury-root .modal-actions { display: flex; gap: 0.8rem; align-items: end; margin-top: auto; flex-wrap: wrap; }
  .quiet-luxury-root .quantity-picker { display: flex; flex-direction: column; gap: 0.3rem; color: var(--muted); font-size: 0.9rem; }
  .quiet-luxury-root .quantity-picker select { border: 1px solid var(--border); border-radius: 999px; padding: 0.7rem 0.9rem; background: #fff; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes backdropIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes modalRise { from { opacity: 0; transform: translateY(10px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

  @media (max-width: 980px) {
    .quiet-luxury-root .app-shell { grid-template-columns: 1fr; }
    .quiet-luxury-root .hero-panel { grid-template-columns: 1fr; }
    .quiet-luxury-root .cart-panel { margin-top: 1rem; }
  }
  @media (max-width: 700px) {
    .quiet-luxury-root .topbar { flex-direction: column; align-items: flex-start; gap: 0.85rem; padding: 1rem 1rem 0.9rem; }
    .quiet-luxury-root .app-shell { padding: 1rem; }
    .quiet-luxury-root .hero-panel, .quiet-luxury-root .cart-panel { padding: 1rem; }
    .quiet-luxury-root .section-heading { flex-direction: column; align-items: flex-start; }
    .quiet-luxury-root .section-heading > p { text-align: left; }
    .quiet-luxury-root .product-grid { grid-template-columns: 1fr; }
    .quiet-luxury-root .modal-card { grid-template-columns: 1fr; }
  }
</style>

<div class="quiet-luxury-root">
  <header class="topbar">
    <div class="brand-block">
      <div class="brand-mark">N</div>
      <div>
        <p class="eyebrow">Boutique online</p>
        <h1>Tienda Nova</h1>
      </div>
    </div>
    <nav class="topnav" aria-label="Categorías principales">
      <button class="tab active" data-category="novedades">Novedades</button>
      <button class="tab" data-category="esenciales">Esenciales</button>
      <button class="tab" data-category="cuidado">Cuidado de la Piel</button>
    </nav>
  </header>

  <main class="app-shell">
    <section class="hero-panel">
      <div class="hero-copy-block">
        <p class="eyebrow">Colección seleccionada</p>
        <h2>Estilo femenino refinado, pensado para cada instante.</h2>
        <p class="hero-copy">Una selección íntima de piezas con presencia serena, materialidad cuidada y un lenguaje visual sobrio.</p>
        <a class="primary-btn" href="#productos">Explorar Colección</a>
      </div>
      <div class="hero-visual">
        <div class="hero-badge">Elegancia atemporal</div>
        <div class="hero-glow"></div>
      </div>
    </section>

    <aside id="carrito" class="cart-panel">
      <div class="cart-header">
        <div>
          <p class="eyebrow">Tu carrito</p>
          <h3>Resumen de compra</h3>
        </div>
        <span id="cart-count" class="pill">0</span>
      </div>
      <div id="cart-items" class="cart-items"><p class="empty-cart">Tu selección aún está vacía.</p></div>
      <div class="cart-summary">
        <div class="summary-row">
          <span>Total</span>
          <strong id="cart-total">$0.00</strong>
        </div>
        <button class="checkout-btn">Finalizar compra</button>
      </div>
    </aside>
  </main>

  <section id="productos" class="catalog-section" style="padding: 0 2rem 2rem;">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Selección editada</p>
        <h3 id="catalog-title">Novedades</h3>
      </div>
      <p>Diseños curados para una estética de lujo silencioso.</p>
    </div>
    <div id="product-grid" class="product-grid"></div>
  </section>

  <div id="quick-view-modal" class="modal hidden" aria-hidden="true">
    <div class="modal-backdrop" data-close-modal="true"></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <button class="modal-close" data-close-modal="true" aria-label="Cerrar">×</button>
      <div class="modal-gallery">
        <div id="modal-visual" class="modal-visual"></div>
        <div id="modal-thumbnails" class="thumbnail-row"></div>
      </div>
      <div class="modal-details">
        <p class="eyebrow">Vista rápida</p>
        <h3 id="modal-title"></h3>
        <p id="modal-description" class="modal-description"></p>
        <ul id="modal-benefits" class="benefits-list"></ul>
        <div class="modal-actions">
          <label class="quantity-picker" for="modal-quantity">
            Cantidad
            <select id="modal-quantity">
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
            </select>
          </label>
          <button id="modal-add-btn" class="primary-btn">Añadir al carrito</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const products = [
    { id: 1, category: 'novedades', name: 'Bolso de Mano en Estructura Rígida', price: 1890, badge: 'Edición limitada', description: 'Una pieza estructurada con una silueta firme, un cierre preciso y una presencia discreta.', benefits: ['Cuero de alta calidad', 'Interior acolchado', 'Cierre magnético'], images: ['👜', '✨', '☁️'] },
    { id: 2, category: 'novedades', name: 'Gafas Cat-Eye Elegantes', price: 980, badge: 'Línea sculpt', description: 'Montura de acetato con forma propuesta para un look sofisticado y femenino.', benefits: ['Ajuste anatómico', 'Protección UV400', 'Acetato de alto brillo'], images: ['🕶️', '🌙', '💫'] },
    { id: 3, category: 'esenciales', name: 'Blazer de Seda Satinada', price: 1640, badge: 'Atemporal', description: 'Chaqueta ligera con caída impecable, pensada para elevar cualquier look.', benefits: ['Textura satinada', 'Corte estructurado', 'Versátil para día y noche'], images: ['🧥', '🌿', '✦'] },
    { id: 4, category: 'cuidado', name: 'Dispositivo de Microcorriente Facial', price: 2490, badge: 'Recomendado', description: 'Tecnología de cuidado facial pensada para una rutina de tratamiento precisa.', benefits: ['Modo suave y profundo', 'Diseño ergonómico', 'Ideal para piel sensible'], images: ['✨', '🫧', '🌸'] },
    { id: 5, category: 'cuidado', name: 'Aceite de Rosa de Noche', price: 760, badge: 'Botánica', description: 'Textura ligera y envolvente para el ritual nocturno.', benefits: ['Con ácido hialurónico', 'Textura sublime', 'Aptos para piel sensible'], images: ['🧴', '🌙', '💧'] }
  ];

  const cart = [];
  const cartItemsEl = document.getElementById('cart-items');
  const cartCountEl = document.getElementById('cart-count');
  const cartTotalEl = document.getElementById('cart-total');
  const productGridEl = document.getElementById('product-grid');
  const catalogTitleEl = document.getElementById('catalog-title');
  const tabs = document.querySelectorAll('.tab');
  const modalEl = document.getElementById('quick-view-modal');
  const modalVisualEl = document.getElementById('modal-visual');
  const modalThumbnailsEl = document.getElementById('modal-thumbnails');
  const modalTitleEl = document.getElementById('modal-title');
  const modalDescriptionEl = document.getElementById('modal-description');
  const modalBenefitsEl = document.getElementById('modal-benefits');
  const modalQuantityEl = document.getElementById('modal-quantity');
  const modalAddBtn = document.getElementById('modal-add-btn');
  let activeCategory = 'novedades';
  let activeModalProductId = null;

  function formatPrice(price) { return '$' + price.toLocaleString('es-MX'); }

  function renderProducts() {
    const filteredProducts = products.filter((product) => product.category === activeCategory);
    const activeTab = Array.from(tabs).find((tab) => tab.dataset.category === activeCategory);
    if (activeTab) catalogTitleEl.textContent = activeTab.textContent.trim();
    tabs.forEach((tab) => tab.classList.toggle('active', tab.dataset.category === activeCategory));
    productGridEl.classList.add('is-changing');
    window.setTimeout(() => {
      productGridEl.innerHTML = filteredProducts.map((product) => `
        <article class="product-card" data-product-id="${product.id}">
          <button class="product-visual" type="button" data-product-id="${product.id}" aria-label="Ver ${product.name}"></button>
          <span class="product-badge">${product.badge}</span>
          <div>
            <h4>${product.name}</h4>
            <p>${product.description}</p>
          </div>
          <div class="product-footer">
            <span>${formatPrice(product.price)}</span>
            <button class="add-btn" type="button" data-product-id="${product.id}">Añadir</button>
          </div>
        </article>
      `).join('');
      productGridEl.classList.remove('is-changing');
    }, 180);
  }

  function renderCart() {
    if (cart.length === 0) {
      cartItemsEl.innerHTML = '<p class="empty-cart">Tu selección aún está vacía.</p>';
      cartCountEl.textContent = '0';
      cartTotalEl.textContent = '$0.00';
      return;
    }
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    const totalPrice = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    cartCountEl.textContent = totalItems.toString();
    cartTotalEl.textContent = formatPrice(totalPrice);
    cartItemsEl.innerHTML = cart.map((item) => `
      <div class="cart-item">
        <div>
          <strong>${item.name}</strong>
          <span>${item.quantity} × ${formatPrice(item.price)}</span>
        </div>
        <span>${formatPrice(item.price * item.quantity)}</span>
      </div>
    `).join('');
  }

  function addToCart(id, quantity = 1) {
    const product = products.find((entry) => entry.id === id);
    if (!product) return;
    const existing = cart.find((item) => item.id === id);
    if (existing) existing.quantity += quantity; else cart.push({ ...product, quantity });
    renderCart();
  }

  function openModal(productId) {
    const product = products.find((entry) => entry.id === productId);
    if (!product) return;
    activeModalProductId = product.id;
    modalTitleEl.textContent = product.name;
    modalDescriptionEl.textContent = product.description;
    modalBenefitsEl.innerHTML = product.benefits.map((benefit) => `<li>${benefit}</li>`).join('');
    modalVisualEl.textContent = product.images[0];
    modalThumbnailsEl.innerHTML = product.images.map((image, index) => `
      <button class="thumbnail-btn ${index === 0 ? 'active' : ''}" type="button" data-index="${index}">${image}</button>
    `).join('');
    modalEl.classList.remove('hidden');
    modalEl.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modalEl.classList.add('hidden');
    modalEl.setAttribute('aria-hidden', 'true');
  }

  function renderModalImage(index) {
    const product = products.find((entry) => entry.id === activeModalProductId);
    if (!product) return;
    modalVisualEl.textContent = product.images[index];
    Array.from(modalThumbnailsEl.children).forEach((button, buttonIndex) => {
      button.classList.toggle('active', buttonIndex === index);
    });
  }

  productGridEl.addEventListener('click', (event) => {
    const button = event.target.closest('button[data-product-id]');
    const card = event.target.closest('.product-card');
    if (!button && !card) return;
    if (button && button.classList.contains('add-btn')) {
      event.stopPropagation();
      addToCart(Number(button.dataset.productId));
      return;
    }
    openModal(Number((button || card).dataset.productId));
  });

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      activeCategory = tab.dataset.category;
      renderProducts();
    });
  });

  modalThumbnailsEl.addEventListener('click', (event) => {
    const button = event.target.closest('.thumbnail-btn');
    if (!button) return;
    renderModalImage(Number(button.dataset.index));
  });

  modalAddBtn.addEventListener('click', () => {
    if (activeModalProductId !== null) {
      addToCart(activeModalProductId, Number(modalQuantityEl.value));
      closeModal();
    }
  });

  document.querySelectorAll('[data-close-modal]').forEach((element) => element.addEventListener('click', closeModal));
  document.querySelector('.checkout-btn').addEventListener('click', () => {
    if (cart.length === 0) {
