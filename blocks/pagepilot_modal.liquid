		{
			"type": "range",
			"id": "margin_top",
			"label": "Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"label": "Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"label": "Mobile Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
			"label": "Mobile Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "header",
			"content": "Modal"
		},
		{
			"type": "checkbox",
			"id": "show_close_button",
			"label": "Show Close Button",
			"default": true
		},
		{
			"type": "text",
			"id": "file_url",
			"label": "File URL (accepts images and pdf)"
		},
		{
			"type": "textarea",
			"id": "custom_html",
			"label": "Custom HTML",
			"info": "You can use this to add custom HTML to the modal. This will be displayed above the file."
		},
		{
			"type": "header",
			"content": "Custom"
		},
		{
			"type": "text",
			"id": "custom_class",
			"label": "Class",
			"info": "You can use this class to add custom styles to the modal. Multiple classes can be added by separating them with a space."
		}
	],
	"presets": [
		{
			"name": "Modal (PP)",
			"category": "PagePilot"
		}
	]
}
{% endschema %}
