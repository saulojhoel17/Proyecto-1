{% comment %}
	@pp blocks/pagepilot-variant-picker 1.0.12
{% endcomment %}

{% liquid
	if closest.product != null
		assign product = closest.product
	endif
%}

{% liquid
	capture container_properties
		echo '--gap: ' | append: block.settings.gap | append: 'px;'

		echo '--margin-top: ' | append: block.settings.margin_top | append: 'px;'
		echo '--margin-bottom: ' | append: block.settings.margin_bottom | append: 'px;'

		assign option_font_color_value = block.settings.option_text_color | default: 'transparent'
		echo '--option-font-color: ' | append: option_font_color_value | append: ';'
		echo '--option-font-size: ' | append: block.settings.option_font_size | append: 'px;'
		echo '--option-font-size-mobile: ' | append: block.settings.option_font_size_mobile | append: 'px;'
		echo '--option-font-weight: ' | append: block.settings.option_weight | default: 'normal' | append: ';'
		echo '--option-gap: ' | append: block.settings.option_gap | append: 'px;'

		echo '--variant-gap: ' | append: block.settings.variant_gap | append: 'px;'
		echo '--variant-padding-y: ' | append: block.settings.variant_padding_y | append: 'px;'
		echo '--variant-padding-x: ' | append: block.settings.variant_padding_x | append: 'px;'

		echo '--variant-font-size: ' | append: block.settings.variant_font_size | append: 'px;'
		echo '--variant-font-size-mobile: ' | append: block.settings.variant_font_size_mobile | append: 'px;'

		echo '--variant-icon-size: ' | append: block.settings.variant_icon_size | append: 'px;'
		echo '--variant-icon-color: ' | append: block.settings.variant_icon_color | append: ';'

		echo '--variant-font-weight: ' | append: block.settings.variant_weight | default: 'normal' | append: ';'
		assign variant_text_color_value = block.settings.variant_text_color | default: 'transparent'
		echo '--variant-text-color: ' | append: variant_text_color_value | append: ';'

		assign variant_bg_value = block.settings.variant_background_color | default: 'transparent'
		echo '--variant-background-color: ' | append: variant_bg_value | append: ';'

		if block.settings.variant_box_shadow_color != blank
			echo '--variant-box-shadow: ' | append: block.settings.variant_box_shadow_color | append: ';'
		endif

		if block.settings.variant_border != 'none' and block.settings.variant_border_color != blank
			echo '--variant-border-width: ' | append: block.settings.variant_border_width | append: 'px;'
			echo '--variant-border-color: ' | append: block.settings.variant_border_color | append: ';'
		endif

		assign opacity_decimal = block.settings.variant_out_of_stock_opacity | times: 0.01
		echo '--variant-out-of-stock-opacity: ' | append: opacity_decimal | append: ';'
		echo '--variant-out-of-stock-strikethrough-height: ' | append: block.settings.variant_out_of_stock_strikethrough_height | append: 'px;'
		assign rotate_value = block.settings.variant_out_of_stock_strikethrough_rotate | times: -1
		echo '--variant-out-of-stock-strikethrough-rotate: ' | append: rotate_value | append: 'deg;'

		assign variant_selected_text_value = block.settings.variant_selected_text_color | default: 'transparent'
		echo '--variant-selected-text-color: ' | append: variant_selected_text_value | append: ';'
		echo '--variant-selected-font-weight: ' | append: block.settings.variant_selected_weight | default: 'normal' | append: ';'
		assign variant_selected_bg_value = block.settings.variant_selected_background_color | default: 'transparent'
		echo '--variant-selected-background-color: ' | append: variant_selected_bg_value | append: ';'
		assign variant_selected_border_value = block.settings.variant_selected_border_color | default: 'transparent'
		echo '--variant-selected-border-color: ' | append: variant_selected_border_value | append: ';'

		if block.settings.swatches_show
			echo '--swatches-size: ' | append: block.settings.swatches_size | append: 'px;'
			echo '--swatches-border-width: ' | append: block.settings.swatches_border_width | append: 'px;'
			echo '--swatches-border-color: ' | append: block.settings.swatches_border_color | append: ';'
			echo '--swatches-selected-border-color: ' | append: block.settings.swatches_selected_border_color | append: ';'
		endif
	endcapture
%}

{% liquid
	assign option_classes = 'pp:text-(length:--option-font-size-mobile) pp:font-(--option-font-weight) pp:text-(--option-font-color) pp:@3xl:text-(length:--option-font-size) pp:mb-(--option-gap)'

	capture letter_spacing
		render 'pagepilot-letter-spacing', value: block.settings.option_letter_spacing
	endcapture

	assign option_classes = option_classes | append: ' ' | append: letter_spacing

	capture text_transform
		render 'pagepilot-text-transform', value: block.settings.option_case
	endcapture
	assign option_classes = option_classes | append: ' ' | append: text_transform
%}

{% liquid
	assign variant_classes = 'pp:relative pp:flex pp:cursor-pointer pp:items-center pp:justify-center pp:gap-2 pp:overflow-hidden pp:bg-(--variant-background-color) pp:leading-none pp:px-(--variant-padding-x)! pp:py-(--variant-padding-y)! pp:text-(length:--variant-font-size-mobile) pp:font-(--variant-font-weight) pp:text-(--variant-text-color) pp:@3xl:text-(length:--variant-font-size)'

	capture border
		render 'pagepilot-border', value: block.settings.variant_border, width_property: '--variant-border-width', color_property: '--variant-border-color'
	endcapture

	assign variant_classes = variant_classes | append: ' ' | append: border

	capture border_radius
		render 'pagepilot-border-radius', value: block.settings.variant_border_radius
	endcapture

	assign variant_classes = variant_classes | append: ' ' | append: border_radius

	capture letter_spacing
		render 'pagepilot-letter-spacing', value: block.settings.variant_letter_spacing
	endcapture

	assign variant_classes = variant_classes | append: ' ' | append: letter_spacing

	capture text_transform
		render 'pagepilot-text-transform', value: block.settings.variant_case
	endcapture
	assign variant_classes = variant_classes | append: ' ' | append: text_transform

	assign variant_classes = variant_classes | append: ' pp:transition-all pp:duration-200 pp:hover:scale-105'

	if block.settings.variant_box_shadow_color
		assign variant_classes = variant_classes | append: ' pp:shadow-(--variant-box-shadow)'
	endif

	assign variant_classes = variant_classes | append: ' pp:has-[:checked]:text-(--variant-selected-text-color) pp:has-[:checked]:font-(--variant-selected-font-weight) pp:has-[:checked]:border-(--variant-selected-border-color) pp:has-[:checked]:bg-(--variant-selected-background-color)'

	assign variant_classes = variant_classes | append: ' pp:has-aria-disabled:opacity-(--variant-out-of-stock-opacity)'

	if block.settings.variant_out_of_stock_strikethrough
		assign variant_classes = variant_classes | append: ' pp:has-aria-disabled:before:absolute pp:has-aria-disabled:before:top-1/2 pp:has-aria-disabled:before:left-1/2 pp:has-aria-disabled:before:h-(--variant-out-of-stock-strikethrough-height) pp:has-aria-disabled:before:w-[150%] pp:has-aria-disabled:before:-translate-x-1/2 pp:has-aria-disabled:before:-translate-y-1/2 pp:has-aria-disabled:before:rotate-(--variant-out-of-stock-strikethrough-rotate) pp:has-aria-disabled:before:transform pp:has-aria-disabled:before:bg-(--variant-text-color) pp:has-aria-disabled:before:opacity-(--variant-out-of-stock-opacity) pp:has-aria-disabled:before:content-[""]'
	endif
%}

{% liquid
	assign swatch_classes = 'pp:size-(--swatches-size)! pp:object-cover'

	capture border
		render 'pagepilot-border', value: block.settings.swatches_border, width_property: '--swatches-border-width', color_property: '--swatches-border-color'
	endcapture

	assign swatch_classes = swatch_classes | append: ' ' | append: border | append: ' pp:peer-checked:border-(--swatches-selected-border-color)'

	capture border_radius
		render 'pagepilot-border-radius', value: block.settings.swatches_border_radius
	endcapture

	assign swatch_classes = swatch_classes | append: ' ' | append: border_radius
%}

{% liquid
	assign swatches_images_pairing_option_downcase = block.settings.swatches_images_pairing_option | downcase

	assign swatch_pairs = '' | split: ''

	assign default_pairs = 'color|white:#ffffff,color|black:#000000,color|gray:#808080,color|light gray:#d3d3d3,color|dark gray:#a9a9a9,color|silver:#c0c0c0,color|ivory:#fffff0,color|cream:#fffdd0,color|beige:#f5f5dc,color|tan:#d2b48c,color|brown:#8b4513,color|coffee:#6f4e37,color|mocha:#967969,color|caramel:#ffddaf,color|camel:#c19a6b,color|sand:#f4e2d8,color|khaki:#f0e68c,color|taupe:#483c32,color|stone:#b7a99a,color|sienna:#a0522d,color|maroon:#800000,color|burgundy:#800020,color|wine:#722f37,color|red:#ff0000,color|scarlet:#ff2400,color|crimson:#dc143c,color|coral:#ff7f50,color|salmon:#fa8072,color|terracotta:#e2725b,color|rust:#b7410e,color|orange:#ffa500,color|dark orange:#ff8c00,color|tangerine:#f28500,color|amber:#ffbf00,color|gold:#ffd700,color|yellow:#ffff00,color|mustard:#ffdb58,color|lemon:#fff44f,color|olive:#808000,color|olive green:#6b8e23,color|lime:#00ff00,color|mint:#98ff98,color|chartreuse:#7fff00,color|green:#008000,color|forest green:#228b22,color|emerald:#50c878,color|jungle green:#29ab87,color|sage:#b2ac88,color|pistachio:#93c572,color|sea green:#2e8b57,color|teal:#008080,color|cyan:#00ffff,color|sky blue:#87ceeb,color|light blue:#add8e6,color|blue:#0000ff,color|royal blue:#4169e1,color|navy:#000080,color|navy blue:#000080,color|midnight blue:#191970,color|indigo:#4b0082,color:denim:#1560bd,color|turquoise:#40e0d0,color|aqua:#00ffff,color|purple:#800080,color|dark violet:#9400d3,color|plum:#dda0dd,color|magenta:#ff00ff,color|fuchsia:#ff00ff,color|pink:#ffc0cb,color|hot pink:#ff69b4,color|rose:#ff007f,color|blush:#de5d83,color|peach:#ffe5b4,color|lavender:#e6e6fa,color|violet:#ee82ee,color|orchid:#da70d6,color|charcoal:#36454f,color|slate gray:#708090,color|ash:#b2beb5,color|graphite:#383838,color|bronze:#a97142,color|rose gold:#f1c0af,color|copper:#b87333,color|champagne:#f7e7ce,color|clear:#f1f5fa,color|denim blue:#1560bd,color|khaki green:#8a9a5b,color|army green:#4b5320,color|camel brown:#c19a6b,color|cream beige:#fffdd0,color|off white:#f9f6ee,color|eggplant:#614051,color|sandstone:#786d5f,color|oatmeal:#d0c8b0,color|platinum:#e5e4e2' | split: ','

	for pair in default_pairs
		assign one = pair | split: '///'
		assign swatch_pairs = swatch_pairs | concat: one
	endfor

	assign user_colors = block.settings.swatches_colors
	if user_colors != blank
		assign user_lines = user_colors | downcase | newline_to_br | split: '<br />'

		assign filtered_pairs = '' | split: ''
		assign user_keys = '' | split: ''

		for raw in user_lines
			assign line = raw | strip
			if line != blank
				assign parts = line | split: ':'
				if parts.size >= 3
					assign option = parts[0] | strip | downcase
					assign value = parts[1] | strip | downcase
					assign key = option | append: '|' | append: value
					assign one_key = key | split: '///'
					assign user_keys = user_keys | concat: one_key
				endif
			endif
		endfor

		for pair in swatch_pairs
			assign pair_parts = pair | split: ':'
			if pair_parts.size >= 2
				assign pair_key = pair_parts[0]

				assign should_keep = true
				for user_key in user_keys
					if user_key == pair_key
						assign should_keep = false
						break
					endif
				endfor

				if should_keep
					assign one = pair | split: '///'
					assign filtered_pairs = filtered_pairs | concat: one
				endif
			endif
		endfor

		assign swatch_pairs = filtered_pairs

		for raw in user_lines
			assign line = raw | strip
			if line != blank
				assign parts = line | split: ':'
				if parts.size >= 3
					assign option = parts[0] | strip | downcase
					assign value = parts[1] | strip | downcase
					assign color = parts | slice: 2, parts.size | join: ':' | strip

					assign pair = option | append: '|' | append: value | append: ':' | append: color
					assign one = pair | split: '///'
					assign swatch_pairs = swatch_pairs | concat: one
				endif
			endif
		endfor
	endif
%}

{% liquid
	assign variant_picker_dropdown_classes = 'pp:relative pp:w-full pp:flex pp:cursor-pointer pp:items-center pp:justify-center pp:gap-2 pp:bg-(--variant-background-color)! pp:px-(--variant-padding-x)! pp:py-(--variant-padding-y)! pp:leading-none pp:text-(length:--variant-font-size-mobile)! pp:font-(--variant-font-weight)! pp:text-(--variant-text-color)! pp:@3xl:text-(length:--variant-font-size)! pp:appearance-none'

	capture border
		render 'pagepilot-border', value: block.settings.variant_border, width_property: '--variant-border-width', color_property: '--variant-border-color'
	endcapture

	assign variant_picker_dropdown_classes = variant_picker_dropdown_classes | append: ' ' | append: border

	capture border_radius
		render 'pagepilot-border-radius', value: block.settings.variant_border_radius
	endcapture

	assign variant_picker_dropdown_classes = variant_picker_dropdown_classes | append: ' ' | append: border_radius

	capture letter_spacing
		render 'pagepilot-letter-spacing', value: block.settings.variant_letter_spacing
	endcapture

	assign variant_picker_dropdown_classes = variant_picker_dropdown_classes | append: ' ' | append: letter_spacing

	capture text_transform
		render 'pagepilot-text-transform', value: block.settings.variant_case
	endcapture
	assign variant_picker_dropdown_classes = variant_picker_dropdown_classes | append: ' ' | append: text_transform

	assign variant_picker_dropdown_icon_classes = 'pp:absolute pp:top-1/2 pp:right-(--variant-padding-x) pp:z-1 pp:size-(--variant-icon-size) pp:-translate-y-1/2 pp:text-(--variant-icon-color)'
%}

{% unless product.has_only_default_variant %}
	<pagepilot-variant-picker
		class='pp-variant-picker pp:relative pp:mx-auto pp:w-full pp:mt-(--margin-top) pp:mb-(--margin-bottom) pp:scroll-m-20'
		data-section-id='{{ section.id }}'
		data-product-id='{{ product.id }}'
		data-block-id='{{ block.id }}'
		data-product-url='{{ product.url }}'
		ref='mainVariantPicker'
		{% if product.id == product.id %}
			data-template-product-match='true'
		{% endif %}
		{{ block.shopify_attributes }}
		style='{{ container_properties }}'
	>
		<form>
			<div class='pp:space-y-(--gap)'>
				{%- for product_option in product.options_with_values -%}
					{%- assign option_name = product_option.name | escape -%}
					{%- if product_option.values.size > 1 -%}
						<fieldset>
							<legend class='{{ option_classes }}'>
								{{ option_name -}}

								{% assign option_name_downcase = option_name | downcase %}

								{%- if option_name_downcase == swatches_images_pairing_option_downcase -%}
									<span class='variant-option__swatch-value'>
										{{- product_option.selected_value -}}
									</span>
								{%- endif %}
							</legend>

							{% if block.settings.variant_picker_style == 'buttons' %}
								<div class='pp:flex pp:flex-wrap pp:gap-(--variant-gap)'>
									{%- for product_option_value in product_option.values -%}
										<label class='{{ variant_classes }}'>
											<input
												type='radio'
												name='{{ product_option.name | escape }}-{{ block.id }}-{{ product.id }}'
												value='{{ product_option_value | escape }}'
												aria-label='{{ product_option_value.name }}'
												{% if product_option_value.available == false
													or block.settings.show_out_of_stock_variants == true
												%}
													aria-disabled='true'
												{% endif %}
												data-input-id='{{ product_option.position }}-{{ forloop.index0 }}'
												data-option-value-id='{{ product_option_value.id }}'
												data-option-available='{{ product_option_value.available }}'
												data-connected-product-url='{{ product_option_value.product_url }}'
												{% if product_option_value.variant.id %}
													data-variant-id='{{ product_option_value.variant.id }}'
												{% endif %}
												{% if product_option_value.selected %}
													checked
												{% endif %}
												class='pp:peer pp:sr-only'
											>

											{% liquid
												assign option_value = product_option_value.name | downcase

												assign key = option_name_downcase | downcase | append: '|' | append: option_value | downcase
												assign needle = key | append: ':'

												assign found_color = ''
												for item in swatch_pairs
													if item contains needle
														assign found_color = item | split: ':' | last
														break
													endif
												endfor
											%}

											{%- if block.settings.swatches_show
												and option_name_downcase == swatches_images_pairing_option_downcase
											-%}
												{% liquid
													assign featured_media = product_option_value.variant.featured_media

													if featured_media == blank and product_option_value.product_url
														assign featured_media = product_option_value.variant.product.featured_media
													endif
												%}

												{% if featured_media != blank %}
													<img
														class='{{ swatch_classes }}'
														src='{{ featured_media | image_url: width: 100 }}'
														alt='{{ featured_media.alt }}'
														width='100'
														height='100'
													>
												{% endif %}

												{% if block.settings.swatches_images_text_hidden == false %}
													<span>{{ product_option_value | escape }}</span>
												{% endif %}
											{% elsif block.settings.swatches_show
												and found_color != ''
												and option_name_downcase != swatches_images_pairing_option_downcase
											%}
												<span
													class='{{ swatch_classes }}'
													style='background-color: {{ found_color }};'
													title='{{ product_option_value.name | escape }}'
												></span>

												{% if block.settings.swatches_colors_text_hidden == false %}
													<span>{{ product_option_value | escape }}</span>
												{% endif %}
											{% else %}
												<span>{{ product_option_value | escape }}</span>
											{% endif %}
										</label>
									{%- endfor -%}
								</div>
							{% else %}
								<div class='pp:relative'>
									<i
										data-lucide='chevron-down'
										class='{{ variant_picker_dropdown_icon_classes }}'
									></i>
									<select
										id='Option-{{ block.id }}-{{ forloop.index0 }}'
										name='options[{{ product_option.name | escape }}]'
										class='{{ variant_picker_dropdown_classes }}'
									>
										{%- for product_option_value in product_option.values -%}
											<option
												value='{{ product_option_value | escape }}'
												data-input-id='{{ product_option.position }}-{{ forloop.index0 }}'
												data-option-value-id='{{ product_option_value.id }}'
												data-variant-id='{{ product_option_value.variant.id }}'
												data-connected-product-url='{{ product_option_value.product_url }}'
												{% if product_option_value.selected %}
													selected='selected'
												{% endif %}
											>
												{{ product_option_value | escape }}
											</option>
										{%- endfor -%}
									</select>
								</div>
							{% endif %}
						</fieldset>
					{%- endif -%}
				{%- endfor -%}
			</div>

			<script type='application/json'>
				{{ product.selected_or_first_available_variant | json }}
			</script>
		</form>
	</pagepilot-variant-picker>
{% endunless %}

{% schema %}
{
	"name": "Variant Picker (PP)",
	"class": "pagepilot-block",
	"settings": [
		{
			"type": "select",
			"id": "variant_picker_style",
			"label": "Style",
			"options": [
				{
					"value": "dropdowns",
					"label": "Dropdowns"
				},
				{
					"value": "buttons",
					"label": "Buttons"
				}
			],
			"default": "buttons"
		},
		{
			"type": "range",
			"id": "gap",
			"label": "Gap",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 16
		},
		{
			"type": "header",
			"content": "Options"
		},
		{
			"type": "color",
			"id": "option_text_color",
			"label": "Text Color",
			"default": "#212529"
		},
		{
			"type": "range",
			"id": "option_font_size",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Size",
			"default": 12
		},
		{
			"type": "range",
			"id": "option_font_size_mobile",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Mobile Size",
			"default": 12
		},
		{
			"type": "select",
			"id": "option_weight",
			"label": "Weight",
			"options": [
				{
					"value": "100",
					"label": "Thin"
				},
				{
					"value": "300",
					"label": "Light"
				},
				{
					"value": "400",
					"label": "Regular"
				},
				{
					"value": "500",
					"label": "Medium"
				},
				{
					"value": "600",
					"label": "Semibold"
				},
				{
					"value": "700",
					"label": "Bold"
				},
				{
					"value": "900",
					"label": "Black"
				}
			],
			"default": "600"
		},
		{
			"type": "select",
			"id": "option_letter_spacing",
			"label": "Letter Spacing",
			"options": [
				{
					"value": "tight",
					"label": "Tight"
				},
				{
					"value": "normal",
					"label": "Normal"
				},
				{
					"value": "loose",
					"label": "Loose"
				}
			],
			"default": "loose"
		},
		{
			"type": "select",
			"id": "option_case",
			"label": "Case",
			"options": [
				{
					"value": "none",
					"label": "Default"
				},
				{
					"value": "lowercase",
					"label": "Lowercase"
				},
				{
					"value": "uppercase",
					"label": "Uppercase"
				},
				{
					"value": "capitalize",
					"label": "Capitalize"
				}
			],
			"default": "uppercase"
		},
		{
			"type": "range",
			"id": "option_gap",
			"label": "Gap",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 6
		},
		{
			"type": "header",
			"content": "Variants"
		},
		{
			"type": "range",
			"id": "variant_icon_size",
