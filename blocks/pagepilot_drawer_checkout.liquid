{% comment %}
	@pp blocks/pagepilot-drawer-checkout 1.0.6
{% endcomment %}

{% render 'pagepilot-button',
	settings: block.settings,
	button_type: 'submit',
	shopify_attributes: block.shopify_attributes,
	drawer_checkout: true,
	cart_empty: cart.empty?
%}

{% schema %}
{
	"name": "Drawer Checkout (PP)",
	"class": "pagepilot-block",
	"settings": [
		{
			"type": "header",
			"content": "Icon"
		},
		{
			"type": "checkbox",
			"id": "icon_show",
			"label": "Show icon",
			"default": true
		},
		{
			"type": "select",
			"id": "icon_position",
			"label": "Icon Position",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "left",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "text",
			"id": "icon",
			"label": "Icon",
			"default": "lock-keyhole",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "range",
			"id": "icon_size",
			"label": "Size",
			"min": 10,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 16,
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "select",
			"id": "icon_variant",
			"label": "Variant",
			"options": [
				{
					"value": "light",
					"label": "Light"
				},
				{
					"value": "regular",
					"label": "Regular"
				},
				{
					"value": "bold",
					"label": "Bold"
				}
			],
			"default": "regular",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "header",
			"content": "Typography"
		},
		{
			"type": "text",
			"id": "text",
			"label": "Text",
			"default": "SECURE CHECKOUT",
			"placeholder": "e.g. Checkout"
		},
		{
			"type": "range",
			"id": "font_size",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Size",
			"default": 15
		},
		{
			"type": "range",
			"id": "font_size_mobile",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Mobile Size",
			"default": 14
		},
		{
			"type": "select",
			"id": "weight",
			"label": "Weight",
			"options": [
				{
					"value": "100",
					"label": "Thin"
				},
				{
					"value": "300",
					"label": "Light"
				},
				{
					"value": "400",
					"label": "Regular"
				},
				{
					"value": "500",
					"label": "Medium"
				},
				{
					"value": "600",
					"label": "Semibold"
				},
				{
					"value": "700",
					"label": "Bold"
				},
				{
					"value": "900",
					"label": "Black"
				}
			],
			"default": "500"
		},
		{
			"type": "select",
			"id": "letter_spacing",
			"label": "Letter Spacing",
			"options": [
				{
					"value": "tight",
					"label": "Tight"
				},
				{
					"value": "normal",
					"label": "Normal"
				},
				{
					"value": "loose",
					"label": "Loose"
				}
			],
			"default": "loose"
		},
		{
			"type": "select",
			"id": "case",
			"label": "Case",
			"options": [
				{
					"value": "none",
					"label": "Default"
				},
				{
					"value": "lowercase",
					"label": "Lowercase"
				},
				{
					"value": "uppercase",
					"label": "Uppercase"
				},
				{
					"value": "capitalize",
					"label": "Capitalize"
				}
			],
			"default": "none"
		},
		{
			"type": "header",
			"content": "Button"
		},
		{
			"type": "color_background",
			"id": "background_color",
			"label": "Background Color",
			"default": "#212529"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text Color",
			"default": "#ffffff"
		},
		{
			"type": "color",
			"id": "hover_text_color",
			"label": "Hover Text Color",
			"default": "#ffffff"
		},
		{
			"type": "select",
			"id": "border",
			"label": "Border Style",
			"options": [
				{
					"value": "none",
					"label": "None"
				},
				{
					"value": "solid",
					"label": "Solid"
				},
				{
					"value": "dashed",
					"label": "Dashed"
				},
				{
					"value": "dotted",
					"label": "Dotted"
				}
			],
			"default": "none"
		},
		{
			"type": "range",
			"id": "border_width",
			"label": "Border Thickness",
			"min": 1,
			"max": 10,
			"step": 1,
			"unit": "px",
			"default": 1,
			"visible_if": "{{ block.settings.border != \"none\" }}"
		},
		{
			"type": "color",
			"id": "border_color",
			"label": "Border Color",
			"default": "#000000",
			"visible_if": "{{ block.settings.border != \"none\" }}"
		},
		{
			"type": "range",
			"id": "border_radius",
			"label": "Rounded Corners",
			"min": 0,
			"max": 100,
			"step": 10,
			"unit": "%",
			"default": 50
		},
		{
			"type": "text",
			"id": "box_shadow_color",
			"label": "Box Shadow"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "text_alignment",
			"id": "text_alignment",
			"label": "Alignment",
			"default": "center"
		},
		{
			"type": "text_alignment",
			"id": "text_alignment_mobile",
			"label": "Mobile Alignment",
			"default": "center"
		},
		{
			"type": "header",
			"content": "Size"
		},
		{
			"type": "select",
			"id": "width",
			"label": "Desktop Width",
			"options": [
				{
					"value": "fit-content",
					"label": "Fit"
				},
				{
					"value": "full-width",
					"label": "Full"
				},
				{
					"value": "custom",
					"label": "Custom"
				}
			],
			"default": "full-width"
		},
		{
			"type": "range",
			"id": "custom_width",
			"label": "Custom width",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 100,
			"visible_if": "{{ block.settings.width == \"custom\" }}"
		},
		{
			"type": "select",
			"id": "width_mobile",
			"label": "Mobile Width",
			"options": [
				{
					"value": "fit-content",
					"label": "Fit"
				},
				{
					"value": "full-width",
					"label": "Full"
				},
				{
					"value": "custom",
					"label": "Custom"
				}
			],
			"default": "full-width"
		},
		{
			"type": "range",
			"id": "custom_width_mobile",
			"label": "Custom width",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 100,
			"visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
		},
		{
			"type": "header",
			"content": "Padding"
		},
		{
			"type": "range",
			"id": "padding_top",
			"label": "Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 14
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"label": "Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 14
		},
		{
			"type": "range",
			"id": "padding_left",
			"label": "Left",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 4
		},
		{
			"type": "range",
			"id": "padding_right",
			"label": "Right",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 4
		},
		{
			"type": "range",
			"id": "padding_top_mobile",
			"label": "Mobile Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 14
		},
		{
			"type": "range",
			"id": "padding_bottom_mobile",
			"label": "Mobile Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 14
		},
		{
			"type": "range",
			"id": "padding_left_mobile",
			"label": "Mobile Left",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 4
		},
		{
			"type": "range",
			"id": "padding_right_mobile",
			"label": "Mobile Right",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 4
		},
		{
			"type": "header",
			"content": "Margin"
		},
		{
			"type": "range",
			"id": "margin_top",
			"label": "Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"label": "Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_top_mobile",
			"label": "Mobile Top",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "range",
			"id": "margin_bottom_mobile",
			"label": "Mobile Bottom",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 0
		},
		{
			"type": "header",
			"content": "Custom"
		},
		{
			"type": "text",
			"id": "custom_class",
			"label": "Class",
			"info": "You can use this class to add custom styles to the button. Multiple classes can be added by separating them with a space."
		}
	],
	"presets": [
		{
			"name": "Drawer Checkout",
			"category": "PagePilot"
		}
	]
}
{% endschema %}
