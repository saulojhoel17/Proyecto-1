				},
				{
					"value": "custom",
					"label": "Custom"
				}
			],
			"default": "fill"
		},
		{
			"type": "select",
			"id": "width_mobile",
			"label": "Mobile Width",
			"options": [
				{
					"value": "fill",
					"label": "Fill"
				},
				{
					"value": "fit",
					"label": "Fit"
				},
				{
					"value": "custom",
					"label": "Custom"
				}
			],
			"default": "fill"
		},
		{
			"type": "select",
			"id": "custom_width_units",
			"label": "Custom Width Units",
			"options": [
				{
					"value": "px",
					"label": "px"
				},
				{
					"value": "%",
					"label": "%"
				}
			],
			"default": "%",
			"visible_if": "{{ block.settings.width == \"custom\" }}"
		},
		{
			"type": "range",
			"id": "custom_width",
			"label": "Custom width",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "-",
			"default": 100,
			"visible_if": "{{ block.settings.width == \"custom\" }}"
		},
		{
			"type": "range",
			"id": "custom_width_mobile",
			"label": "Custom width",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "-",
			"default": 100,
			"visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
		},
		{
			"type": "checkbox",
			"id": "margin_x_auto",
			"label": "Centered",
			"default": false,
			"visible_if": "{{ block.settings.width == \"fit\" or block.settings.width == \"custom\" }}"
		},
		{
			"type": "checkbox",
			"id": "margin_x_auto_mobile",
			"label": "Mobile Centered",
			"default": false,
			"visible_if": "{{ block.settings.width == \"fit\" or block.settings.width == \"custom\" }}"
		},
		{
			"type": "select",
			"id": "height",
