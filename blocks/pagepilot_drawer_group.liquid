			"type": "range",
			"id": "order_mobile",
			"label": "Mobile Order",
			"min": 0,
			"max": 20,
			"step": 1,
			"default": 0
		},
		{
			"type": "header",
			"content": "Size"
		},
		{
			"type": "select",
			"id": "width",
			"label": "Width",
			"options": [
				{
					"value": "fill",
