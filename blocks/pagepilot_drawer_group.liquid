				}
			],
			"default": "start",
			"visible_if": "{{ block.settings.type == \"grid\" }}"
		},
		{
			"type": "select",
			"id": "grid_position_x_mobile",
			"label": "Mobile Position X",
			"options": [
				{
					"value": "start",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "end",
					"label": "Right"
				}
			],
			"default": "start",
			"visible_if": "{{ block.settings.type == \"grid\" }}"
		},
		{
			"type": "select",
			"id": "grid_position_y",
