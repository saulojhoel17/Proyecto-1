{% comment %}
	@pp blocks/pagepilot-drawer-group 1.0.6
{% endcomment %}

{% capture child_blocks %}
	{% content_for 'blocks' %}
{% endcapture %}

{% render 'pagepilot-group', block: block, child_blocks: child_blocks %}

{% schema %}
{
	"name": "Group (PP)",
	"class": "pagepilot-block",
	"blocks": [
		{
			"type": "@theme"
		}
	],
	"settings": [
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "type",
			"label": "Type",
			"options": [
				{
					"value": "flex",
					"label": "Flex"
				},
				{
					"value": "grid",
					"label": "Grid"
				}
			],
			"default": "flex"
		},
		{
			"type": "range",
			"id": "columns",
			"label": "Columns",
			"min": 1,
			"max": 6,
			"step": 1,
			"unit": "col",
			"default": 1,
			"visible_if": "{{ block.settings.type == \"grid\" }}"
		},
		{
			"type": "range",
			"id": "columns_mobile",
			"label": "Mobile Columns",
			"min": 1,
			"max": 3,
			"step": 1,
			"unit": "col",
			"default": 1,
			"visible_if": "{{ block.settings.type == \"grid\" }}"
		},
		{
			"type": "select",
			"id": "content_direction",
			"label": "Content direction",
			"options": [
				{
					"value": "row",
					"label": "Horizontal"
				},
				{
					"value": "column",
					"label": "Vertical"
				}
			],
			"default": "column",
			"visible_if": "{{ block.settings.type == \"flex\" }}"
		},
		{
			"type": "select",
			"id": "content_direction_mobile",
			"label": "Mobile Content direction",
			"options": [
				{
					"value": "row",
					"label": "Horizontal"
				},
				{
					"value": "column",
					"label": "Vertical"
				}
			],
			"default": "column",
			"visible_if": "{{ block.settings.type == \"flex\" }}"
		},
		{
			"type": "select",
			"id": "horizontal_alignment",
			"label": "Position X",
			"options": [
				{
					"value": "flex-start",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Right"
				},
				{
					"value": "space-between",
					"label": "Space between"
				},
				{
					"value": "space-around",
					"label": "Space around"
				}
			],
			"default": "flex-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction == \"row\" }}"
		},
		{
			"type": "select",
			"id": "horizontal_alignment_mobile",
			"label": "Mobile Position X",
			"options": [
				{
					"value": "flex-start",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Right"
				},
				{
					"value": "space-between",
					"label": "Space between"
				},
				{
					"value": "space-around",
					"label": "Space around"
				}
			],
			"default": "flex-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction_mobile == \"row\" }}"
		},
		{
			"type": "select",
			"id": "horizontal_position",
			"label": "Position Y",
			"options": [
				{
					"value": "flex-start",
					"label": "Top"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Bottom"
				}
			],
			"default": "center",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction == \"row\" }}"
		},
		{
			"type": "select",
			"id": "horizontal_position_mobile",
			"label": "Mobile Position (Horizontal)",
			"options": [
				{
					"value": "flex-start",
					"label": "Top"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Bottom"
				}
			],
			"default": "center",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction_mobile == \"row\" }}"
		},
		{
			"type": "select",
			"id": "vertical_alignment",
			"label": "Position Y",
			"options": [
				{
					"value": "justify-start",
					"label": "Top"
				},
				{
					"value": "justify-center",
					"label": "Center"
				},
				{
					"value": "justify-end",
					"label": "Bottom"
				},
				{
					"value": "space-between",
					"label": "Space between"
				},
				{
					"value": "space-around",
					"label": "Space around"
				}
			],
			"default": "justify-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction == \"column\" }}"
		},
		{
			"type": "select",
			"id": "vertical_alignment_mobile",
			"label": "Mobile Position Y",
			"options": [
				{
					"value": "justify-start",
					"label": "Top"
				},
				{
					"value": "justify-center",
					"label": "Center"
				},
				{
					"value": "justify-end",
					"label": "Bottom"
				},
				{
					"value": "space-between",
					"label": "Space between"
				},
				{
					"value": "space-around",
					"label": "Space around"
				}
			],
			"default": "justify-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction_mobile == \"column\" }}"
		},
		{
			"type": "select",
			"id": "vertical_position",
			"label": "Position X",
			"options": [
				{
					"value": "flex-start",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Right"
				}
			],
			"default": "flex-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction == \"column\" }}"
		},
		{
			"type": "select",
			"id": "vertical_position_mobile",
			"label": "Mobile Position X",
			"options": [
				{
					"value": "flex-start",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "flex-end",
					"label": "Right"
				}
			],
			"default": "flex-start",
			"visible_if": "{{ block.settings.type == \"flex\" and block.settings.content_direction_mobile == \"column\" }}"
		},
		{
			"type": "checkbox",
