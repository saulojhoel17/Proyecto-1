			"options": [
				{
					"value": "start",
					"label": "Top"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "end",
					"label": "Bottom"
				}
			],
			"default": "start",
			"visible_if": "{{ block.settings.type == \"grid\" }}"
		},
		{
			"type": "select",
			"id": "grid_position_y_mobile",
