{% comment %}
	@pp blocks/static-pagepilot-add-to-cart 1.0.7
{% endcomment %}

{%- doc -%}
	@param {object} product - The product object to be added to the cart.
{%- enddoc -%}

{% liquid
	assign product_variant_media = product.selected_or_first_available_variant.featured_media.preview_image | image_url: width: 100
	if product.selected_or_first_available_variant.featured_media.preview_image == blank
		assign product_variant_media = product.featured_media.preview_image | image_url: width: 100
	endif

	assign variant = product.selected_or_first_available_variant
	assign inventory_quantity = variant.inventory_quantity
	assign inventory_policy = variant.inventory_policy

	if variant.inventory_management == 'shopify'
		assign inventory_managed = true
	endif

	if variant.quantity_rule.min > variant.inventory_quantity and inventory_managed and inventory_policy == 'deny'
		assign quantity_rule_soldout = true
	endif

	if inventory_managed
		if inventory_quantity <= 0 and inventory_policy == 'deny' or quantity_rule_soldout
			assign can_add_to_cart = false
			assign add_to_cart_text = block.settings.button_sold_out_text
		else
			assign can_add_to_cart = true
			assign add_to_cart_text = block.settings.button_add_to_cart_text
		endif
	else
		if variant != null
			assign can_add_to_cart = true
			assign add_to_cart_text = block.settings.button_add_to_cart_text
		else
			assign can_add_to_cart = false
			assign add_to_cart_text = block.settings.button_unavailable_text
		endif
	endif
%}

{% liquid
	capture properties
		echo '--button-height: ' | append: block.settings.button_height | append: 'px;'

		echo '--icon-size: ' | append: block.settings.icon_size | append: 'px;'
		echo '--font-size: ' | append: block.settings.font_size | append: 'px;'
		echo '--font-size-mobile: ' | append: block.settings.font_size_mobile | append: 'px;'
		echo '--font-weight: ' | append: block.settings.weight | append: ';'
		echo '--text-color: ' | append: block.settings.text_color | append: ';'
		if block.settings.hover_text_color != blank
			echo '--hover-text-color: ' | append: block.settings.hover_text_color | append: ';'
		endif
		if block.settings.background_color != blank
			echo 'background: ' | append: block.settings.background_color | append: ';'
		endif

		if block.settings.border != 'none' and block.settings.border_color != blank
			echo '--border-width: ' | append: block.settings.border_width | append: 'px;'
			echo '--border-color: ' | append: block.settings.border_color | append: ';'
		endif

		if block.settings.box_shadow_color != blank
			echo '--box-shadow: ' | append: block.settings.box_shadow_color | append: ';'
		endif
	endcapture

	assign classes = 'pp-add-to-cart'

	if block.settings.custom_class != blank
		assign classes = classes | append: ' ' | append: block.settings.custom_class
	endif

	assign classes = classes | append: ' pp:decoration-none pp:flex pp:h-(--button-height) pp:w-full pp:cursor-pointer pp:scroll-m-20 pp:appearance-none pp:content-center pp:items-center pp:justify-center pp:gap-3 pp:text-center pp:leading-none pp:wrap-anywhere pp:text-(--text-color)! pp:hover:text-(--hover-text-color)!'
	assign classes = classes | append: ' pp:text-(length:--font-size-mobile) pp:font-(--font-weight) pp:@3xl:text-(length:--font-size)'
	assign classes = classes | append: ' pp:relative pp:z-1 pp:overflow-hidden pp:before:absolute pp:before:inset-0 pp:before:z-[-1] pp:before:bg-white/0 pp:before:content-[""]'
	assign classes = classes | append: ' pp:transition-all pp:duration-200 pp:before:transition-all pp:before:duration-200 pp:hover:before:bg-white/20'

	if block.settings.hover_animation
		assign classes = classes | append: ' pp:scale-100 pp:hover:scale-101'
	endif

	capture letter_spacing
		render 'pagepilot-letter-spacing', value: block.settings.letter_spacing
	endcapture
	assign classes = classes | append: ' ' | append: letter_spacing

	capture border_classes
		render 'pagepilot-border', value: block.settings.border, prefix: 'pp:', width_property: '--border-width', color_property: '--border-color'
	endcapture
	assign classes = classes | append: ' ' | append: border_classes

	capture border_radius
		render 'pagepilot-border-radius', value: block.settings.border_radius, prefix: 'pp:'
	endcapture
	assign classes = classes | append: ' ' | append: border_radius

	if block.settings.box_shadow_color != blank
		assign classes = classes | append: ' pp:shadow-(--box-shadow)'
	endif

	capture text_transform
		render 'pagepilot-text-transform', value: block.settings.case
	endcapture
	assign classes = classes | append: ' ' | append: text_transform

	assign classes = classes | append: ' pp:[&.atc-added]:cursor-not-allowed pp:[&.atc-added]:opacity-50'
	assign classes = classes | append: ' pp:disabled:opacity-50 pp:disabled:cursor-not-allowed'
%}

{% liquid
	assign icon_classes = 'pp:size-(--icon-size)'

	case block.settings.icon_variant
		when 'light'
			assign icon_classes = icon_classes | append: ' pp:stroke-1'
		when 'regular'
			assign icon_classes = icon_classes | append: ' pp:stroke-2'
		when 'bold'
			assign icon_classes = icon_classes | append: ' pp:stroke-3'
	endcase
%}

<pagepilot-add-to-cart-component
	{{ block.shopify_attributes }}
	ref='addToCartButtonContainer'
	data-product-variant-media='{{ product_variant_media }}'
	data-add-to-cart-animation='{{ settings.add_to_cart_animation }}'
>
	<button
		type='submit'
		name='add'
		ref='addToCartButton'
		on:click='/handleClick'
		class='{{ classes }}'
		style='{{ properties }}'
		{% unless can_add_to_cart %}
			disabled
		{% endunless %}
	>
		{% if can_add_to_cart and block.settings.icon_show and block.settings.icon_position == 'left' %}
			<i data-lucide='{{ block.settings.icon }}' class='{{ icon_classes }}'></i>
		{% endif %}
		<span>
			{{- add_to_cart_text -}}
		</span>
		{% if can_add_to_cart and block.settings.icon_show and block.settings.icon_position == 'right' %}
			<i data-lucide='{{ block.settings.icon }}' class='{{ icon_classes }}'></i>
		{% endif %}
	</button>
</pagepilot-add-to-cart-component>

{% schema %}
{
	"name": "Add to Cart (PP)",
	"class": "pagepilot-block",
	"settings": [
		{
			"type": "header",
			"content": "Icon"
		},
		{
			"type": "checkbox",
			"id": "icon_show",
			"label": "Show icon",
			"default": true
		},
		{
			"type": "select",
			"id": "icon_position",
			"label": "Icon Position",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "left",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "text",
			"id": "icon",
			"label": "Icon",
			"default": "shopping-cart",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "range",
			"id": "icon_size",
			"label": "Size",
			"min": 10,
			"max": 100,
			"step": 1,
			"unit": "px",
			"default": 18,
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "select",
			"id": "icon_variant",
			"label": "Variant",
			"options": [
				{
					"value": "light",
					"label": "Light"
				},
				{
					"value": "regular",
					"label": "Regular"
				},
				{
					"value": "bold",
					"label": "Bold"
				}
			],
			"default": "regular",
			"visible_if": "{{ block.settings.icon_show == true }}"
		},
		{
			"type": "header",
			"content": "Button"
		},
		{
			"type": "text",
			"id": "button_add_to_cart_text",
			"label": "Add to Cart Label",
			"default": "Add to Cart"
		},
		{
			"type": "text",
			"id": "button_sold_out_text",
			"label": "Sold Out Label",
			"default": "Sold Out"
		},
		{
			"type": "text",
			"id": "button_unavailable_text",
			"label": "Unavailable Label",
			"default": "Unavailable"
		},
		{
			"type": "range",
			"id": "button_height",
			"label": "Height",
			"min": 30,
			"max": 52,
			"step": 1,
			"unit": "px",
			"default": 52
		},
		{
			"type": "color_background",
			"id": "background_color",
			"label": "Background Color",
			"default": "#000000"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Text Color",
			"default": "#ffffff"
		},
		{
			"type": "color",
			"id": "hover_text_color",
			"label": "Hover Text Color",
			"default": "#ffffff"
		},
		{
			"type": "checkbox",
			"id": "hover_animation",
			"label": "Hover Animation",
			"default": false
		},
		{
			"type": "select",
			"id": "border",
			"label": "Border Style",
			"options": [
				{
					"value": "none",
					"label": "None"
				},
				{
					"value": "solid",
					"label": "Solid"
				},
				{
					"value": "dashed",
					"label": "Dashed"
				},
				{
					"value": "dotted",
					"label": "Dotted"
				}
			],
			"default": "none"
		},
		{
			"type": "range",
			"id": "border_width",
			"label": "Border Thickness",
			"min": 1,
			"max": 10,
			"step": 1,
			"unit": "px",
			"default": 1,
			"visible_if": "{{ block.settings.border != \"none\" }}"
		},
		{
			"type": "color",
			"id": "border_color",
			"label": "Border Color",
			"default": "#000000",
			"visible_if": "{{ block.settings.border != \"none\" }}"
		},
		{
			"type": "range",
			"id": "border_radius",
			"label": "Rounded Corners",
			"min": 0,
			"max": 100,
			"step": 10,
			"unit": "%",
			"default": 50
		},
		{
			"type": "text",
			"id": "box_shadow_color",
			"label": "Box Shadow"
		},
		{
			"type": "header",
			"content": "Typography"
		},
		{
			"type": "range",
			"id": "font_size",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Size",
			"default": 14
		},
		{
			"type": "range",
			"id": "font_size_mobile",
			"min": 10,
			"max": 70,
			"step": 1,
			"unit": "px",
			"label": "Mobile Size",
			"default": 14
		},
		{
			"type": "select",
			"id": "weight",
			"label": "Weight",
			"options": [
				{
					"value": "100",
					"label": "Thin"
				},
				{
					"value": "300",
					"label": "Light"
				},
				{
					"value": "400",
					"label": "Regular"
				},
				{
					"value": "500",
					"label": "Medium"
				},
				{
					"value": "600",
					"label": "Semibold"
				},
				{
					"value": "700",
					"label": "Bold"
				},
				{
					"value": "900",
					"label": "Black"
				}
			],
			"default": "500"
		},
		{
			"type": "select",
			"id": "letter_spacing",
			"label": "Letter Spacing",
			"options": [
				{
					"value": "tight",
					"label": "Tight"
				},
				{
					"value": "normal",
					"label": "Normal"
				},
				{
					"value": "loose",
					"label": "Loose"
				}
			],
			"default": "normal"
		},
		{
			"type": "select",
			"id": "case",
			"label": "Case",
			"options": [
				{
					"value": "none",
					"label": "Default"
				},
				{
					"value": "lowercase",
					"label": "Lowercase"
				},
				{
					"value": "uppercase",
					"label": "Uppercase"
				},
				{
					"value": "capitalize",
					"label": "Capitalize"
				}
			],
			"default": "none"
		},
		{
			"type": "header",
			"content": "Custom"
		},
		{
			"type": "text",
			"id": "custom_class",
			"label": "Class",
			"info": "You can use this class to add custom styles to the custom HTML. Multiple classes can be added by separating them with a space."
		}
	]
}
{% endschema %}
